{
  "entities": {
    "user": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "credits": { "type": "integer", "default": 0 },
        "hasSeenOnboarding": { "type": "boolean", "default": false },
        "fulfilled_sessions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "createdAt", "credits"]
    },
    "generation": {
      "title": "Generation",
      "description": "A saved blog post generation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "title": { "type": "string" },
        "preferences": {
          "type": "object",
          "properties": {
            "targetAudience": { "type": "array", "items": { "type": "string" } },
            "tone": { "type": "array", "items": { "type": "string" } },
            "length": { "type": "string" },
            "specificFocus": { "type": "string" },
            "model": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["processing", "completed", "failed"], "default": "completed" },
        "fileIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "file": {
      "title": "File",
      "description": "Uploaded media file content and metadata",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "generationId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "integer" },
        "data": { "type": "string", "description": "Base64 encoded file data (legacy)" },
        "storageUrl": { "type": "string", "description": "Firebase Storage download URL" },
        "createdAt": { "type": "string", "format": "date-time" },
        "uri": { "type": "string", "description": "Gemini File API URI" },
        "mimeType": { "type": "string" },
        "extractedText": { "type": "string" }
      },
      "required": ["userId", "name", "type", "createdAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Indicates administration status",
      "type": "object",
      "properties": {},
      "required": []
    },
    "userKeys": {
      "title": "UserKeys",
      "description": "Private API keys and sensitive settings",
      "type": "object",
      "properties": {
        "openRouterKey": { "type": "string" }
      }
    },
    "asset": {
      "title": "Asset",
      "description": "Any user asset to test RBAC",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "ownerRole": { "type": "string", "enum": ["user", "admin"] },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "ownerRole", "name", "createdAt"]
    },
    "activity": {
      "title": "Activity",
      "description": "Credit transaction and usage history",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" },
        "cost": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "description", "cost", "timestamp"]
    },
    "media_asset": {
      "title": "Media Asset",
      "description": "Generated or uploaded media files tied to a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "audio"] },
        "source": { "type": "string", "enum": ["uploaded", "generated"] },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "model": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "userId", "type", "source", "name", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "Individual user profiles"
    },
    "users/{userId}/media_assets/{assetId}": {
      "schema": "media_asset",
      "description": "User generated or uploaded media assets stored within Synthesis Studio"
    },
    "users/{userId}/private/keys": {
      "schema": "userKeys",
      "description": "Sensitive user keys"
    },
    "admins/{userId}": {
      "schema": "admin",
      "description": "Users with admin privileges"
    },
    "generations/{generationId}": {
      "schema": "generation",
      "description": "Saved generations for history"
    },
    "files/{fileId}": {
      "schema": "file",
      "description": "Uploaded file assets"
    },
    "assets/{assetId}": {
      "schema": "asset",
      "description": "User assets"
    },
    "users/{userId}/activity/{activityId}": {
      "schema": "activity",
      "description": "User credit activity records"
    }
  }
}
