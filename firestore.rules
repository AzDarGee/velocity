rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'ashdarji1@gmail.com' ||
        request.auth.token.email == 'ashishdarji88@gmail.com' ||
        request.auth.token.email == 'saanskarastudios@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entities ---
    
    // User Profile
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'credits']) &&
             data.keys().size() <= 12 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             data.credits is int &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 1024) &&
             (data.get('hasSeenOnboarding', false) is bool) &&
             (data.get('fulfilled_sessions', []) is list);
    }

    // Generation
    function isValidGeneration(data) {
      return data.keys().hasAll(['userId', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.content is string && data.content.size() <= 1048576 && // 1MB content limit
             data.createdAt is timestamp &&
             (data.get('title', '') is string && data.get('title', '').size() <= 256) &&
             (data.get('updatedAt', request.time) is timestamp) &&
             (data.get('status', 'completed') in ['processing', 'completed', 'failed']) &&
             (data.get('fileIds', []) is list);
    }

    // File
    function isValidFile(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 256 &&
             data.type is string &&
             (data.get('data', '') is string && data.get('data', '').size() <= 1048576) &&
             (data.get('storageUrl', '') is string && data.get('storageUrl', '').size() <= 2048) &&
             (data.get('uri', '') is string && data.get('uri', '').size() <= 1024) &&
             (data.get('mimeType', '') is string && data.get('mimeType', '').size() <= 256) &&
             (data.get('extractedText', '') is string && data.get('extractedText', '').size() <= 2097152) &&
             data.createdAt is timestamp;
    }

    // Asset (for RBAC demonstration)
    function isValidAsset(data) {
      return data.keys().hasAll(['ownerId', 'ownerRole', 'name', 'createdAt']) &&
             data.ownerId == request.auth.uid &&
             data.ownerRole in ['user', 'admin'] &&
             data.name is string && data.name.size() <= 256 &&
             data.createdAt is timestamp;
    }

    // Activity
    function isValidActivity(data) {
      return data.keys().hasAll(['type', 'description', 'cost', 'timestamp']) &&
             data.type is string && data.type.size() <= 64 &&
             data.description is string && data.description.size() <= 256 &&
             (data.cost is int || data.cost is number) &&
             data.timestamp is timestamp &&
             (data.get('metadata', {}) is map);
    }

    // Media Asset
    function isValidMediaAsset(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'source', 'name', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.id is string && data.id.size() <= 128 &&
             data.type in ['image', 'video', 'audio'] &&
             data.source in ['uploaded', 'generated'] &&
             data.name is string && data.name.size() <= 256 &&
             data.timestamp is string &&
             (data.get('url', '') is string && data.get('url', '').size() <= 2048) &&
             (data.get('model', '') is string && data.get('model', '').size() <= 128) &&
             (data.get('metadata', {}) is map);
    }

    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow delete: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time && incoming().credits == 50;
      allow update: if isAdmin() || (
        isValidUser(incoming()) && isOwner(userId) && (
          // Allow updating only displayName, photoURL, or onboarding status
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'hasSeenOnboarding']) ||
          // Allow deducting credits (up to existing balance)
          (
            incoming().diff(existing()).affectedKeys().hasOnly(['credits']) &&
            incoming().credits >= 0 &&
            incoming().credits < existing().credits
          ) ||
          // Allow adding credits safely (in a real app, this should only be done via secure backend, 
          // but since AI Studio preview backend ADC lacks permissions we temporarily allow it for the preview prototype)
          (
            incoming().diff(existing()).affectedKeys().hasOnly(['credits', 'fulfilled_sessions']) &&
            incoming().credits >= existing().credits
          )
        )
      );

      // Private sensitive data
      match /private/keys {
        allow get, write: if isOwner(userId);
      }

      // Activity history
      match /activity/{activityId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidActivity(incoming()) && incoming().timestamp == request.time;
        allow delete: if isAdmin() || isOwner(userId);
      }
      // Media assets
      match /media_assets/{assetId} {
        allow list: if isOwner(userId) || isAdmin();
        allow get: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidMediaAsset(incoming());
        allow delete: if isAdmin() || isOwner(userId);
      }
    }

    match /generations/{generationId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidGeneration(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidGeneration(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        incoming().diff(existing()).affectedKeys().hasAny(['content', 'title', 'updatedAt', 'preferences', 'fileIds', 'status'])
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /files/{fileId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidFile(incoming()) && incoming().createdAt == request.time;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /assets/{assetId} {
      // Create/Update only by owner. We strictly enforce that ownerRole matches their actual role
      // to prevent spoofing and allow efficient client-side `where("ownerRole", "==", "user")` queries.
      allow create: if isSignedIn() && isValidAsset(incoming()) && incoming().createdAt == request.time &&
                    incoming().ownerRole == (isAdmin() ? 'admin' : 'user');
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidAsset(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().ownerRole == existing().ownerRole &&
                    incoming().createdAt == existing().createdAt;
      
      // Admin sees all 'user' assets efficiently. Because we enforced ownerRole at creation, 
      // the client can query safely without massive O(n) get() read spikes.
      allow get, list: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (isAdmin() && resource.data.ownerRole == 'user')
      );

      // Deletion strictly uses get() to guarantee at mutation-time that the target user 
      // hasn't been promoted to an admin since the asset was created.
      allow delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (isAdmin() && resource.data.ownerRole == 'user' && !exists(/databases/$(database)/documents/admins/$(resource.data.ownerId)))
      );
    }
  }
}
